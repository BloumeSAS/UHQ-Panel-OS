# ============================================================================
# UHQ Panel OS — variables d'environnement
# Copier en `.env` et renseigner. Tout ce qui est éditable depuis le panel admin
# (nom du site, logo, intervalles scraper/checker, proxy de secours…) peut rester
# vide ici : la config en base prime, l'env n'est qu'un repli initial.
# ============================================================================

# --- Base de données --------------------------------------------------------
# OPTIONNEL : si vide, l'app démarre et propose de saisir le lien au 1er setup
# (ou utilisez docker-compose.yml qui embarque PostgreSQL 18).
DATABASE_URL=postgresql://user:password@localhost:5432/uhqpanel
# Dossier de config runtime persistante (lien base saisi au setup, etc.).
DATA_DIR=./data

# --- Auth panel -------------------------------------------------------------
# Secret de signature des JWT (mettre une longue chaîne aléatoire en prod).
JWT_SECRET=change-me-with-a-long-random-string
# Graine initiale de la CLÉ API de l'API legacy /api/v1. Une clé est générée au
# setup et régénérable depuis le panel (Paramètres → Clé API). Laisser vide en prod.
ADMIN_PASSWORD=

# --- Réseau -----------------------------------------------------------------
PROXY_HOST=0.0.0.0
PROXY_PORT=990
API_PORT=8000

# --- Repli config (éditable ensuite depuis le panel) ------------------------
PUBLIC_PROXY_HOST=prx.uhq.monster
PUBLIC_PROXY_PORT=990
PROXY_TIMEOUT=3
PROXY_RACING_TIMEOUT=1.5
SCRAPE_INTERVAL=3600
PROXY_CHECK_INTERVAL=900
GEO_RESOLVE_INTERVAL=600
CHECKER_CONCURRENCY=500

# --- Secrets optionnels -----------------------------------------------------
# Proxy résidentiel de secours (fallback) + proxy de sortie scraper/géo.
# Éditable ensuite depuis le panel (Paramètres).
SCRAPER_PROXY=
# Active le provider de scraping IA (Groq). No-op si vide. (Seule source par
# défaut ; les autres sources se configurent dans le panel : URL + regex.)
GROQ_API_KEY=
# URL JSON { "version": "x.y.z" } pour la vérification de MAJ (page À propos). Optionnel.
UPDATE_CHECK_URL=
# Fuseau horaire du conteneur.
TZ=Europe/Paris
